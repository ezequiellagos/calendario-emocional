---
import BackToCalendarLink from '@/components/navigation/BackToCalendarLink';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getRequestAuth } from '@/lib/auth';
import { getStatusPageData } from '@/services/calendar-service';

const auth = getRequestAuth(Astro.locals);
if (!auth.userId) {
  return auth.redirectToSignIn();
}

const data = await getStatusPageData(auth.userId);
---

<BaseLayout title="Estado | Calendario emocional" description="Diagnóstico y estado de sincronización de tu calendario emocional.">
  <main class="mx-auto max-w-[1440px] px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
    <section class="grid gap-4 xl:grid-cols-[1.15fr_0.85fr]">
      <article class="surface-panel shadow-soft overflow-hidden rounded-[2rem] border border-white/60">
        <div class="space-y-6 p-6 md:p-8">
          <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-3">
              <div class="flex flex-wrap gap-2">
                <span class="inline-flex w-fit items-center rounded-full bg-primary/12 px-3 py-1 text-xs font-semibold text-primary">
                  Estado del sistema
                </span>
                <span class="inline-flex w-fit items-center rounded-full border border-border bg-white/70 px-3 py-1 text-xs font-semibold text-foreground">
                  {data.syncEnabled ? 'Mongo central activo' : 'Solo almacenamiento local'}
                </span>
              </div>
              <div class="space-y-2">
                <h1 class="max-w-3xl text-5xl leading-none sm:text-6xl">Estado y diagnóstico</h1>
                <p class="max-w-2xl text-sm text-muted-foreground sm:text-base">
                  Revisa cursores, últimos intercambios y errores de sincronización sin cargar esa información en la vista principal.
                </p>
              </div>
            </div>

            <div class="flex flex-wrap gap-3">
              <BackToCalendarLink />
              <a
                href="/configuracion"
                class="inline-flex h-11 items-center justify-center rounded-full border border-border bg-white/70 px-5 text-sm font-semibold text-foreground transition-all duration-150 hover:-translate-y-0.5 hover:bg-white active:translate-y-px active:scale-[0.98]"
              >
                Abrir configuración
              </a>
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-[1.5rem] bg-white/75 p-4">
              <p class="text-sm text-muted-foreground">Pendientes en SQLite</p>
              <p class="mt-2 text-3xl font-semibold">{data.syncDiagnostics.pendingOperations}</p>
            </div>
            <div class="rounded-[1.5rem] bg-white/75 p-4">
              <p class="text-sm text-muted-foreground">Último pull/aplicados</p>
              <p class="mt-2 text-3xl font-semibold">{data.syncDiagnostics.lastPulledOperations}/{data.syncDiagnostics.lastAppliedOperations}</p>
            </div>
            <div class="rounded-[1.5rem] bg-white/75 p-4">
              <p class="text-sm text-muted-foreground">Último push</p>
              <p class="mt-2 text-sm font-semibold">{data.syncDiagnostics.lastPushAt ?? 'Sin registros'}</p>
            </div>
            <div class="rounded-[1.5rem] bg-white/75 p-4">
              <p class="text-sm text-muted-foreground">Último pull</p>
              <p class="mt-2 text-sm font-semibold">{data.syncDiagnostics.lastPullAt ?? 'Sin registros'}</p>
            </div>
          </div>
        </div>
      </article>

      <article class="surface-panel shadow-soft rounded-[2rem] border border-white/60 p-6">
        <div class="rounded-[1.5rem] border border-border bg-white/70 p-4 text-sm">
          <div class="flex items-center justify-between gap-3">
            <span class="text-muted-foreground">Instancia local</span>
            <span class="font-mono text-xs">{data.syncDiagnostics.instanceId ? data.syncDiagnostics.instanceId.slice(0, 8) : 'sin ID'}</span>
          </div>
          <div class="mt-3 grid gap-2 sm:grid-cols-2">
            <div>
              <p class="text-muted-foreground">Cursor push</p>
              <p class="break-all font-semibold">{data.syncDiagnostics.pushCursor ?? 'sin cursor'}</p>
            </div>
            <div>
              <p class="text-muted-foreground">Cursor pull</p>
              <p class="break-all font-semibold">{data.syncDiagnostics.pullCursor ?? 'sin cursor'}</p>
            </div>
            <div>
              <p class="text-muted-foreground">Enviadas</p>
              <p class="font-semibold">{data.syncDiagnostics.lastPushedOperations}</p>
            </div>
            <div>
              <p class="text-muted-foreground">Traídas</p>
              <p class="font-semibold">{data.syncDiagnostics.lastPulledOperations}</p>
            </div>
          </div>
          {data.syncDiagnostics.lastError ? (
            <p class="mt-3 rounded-xl bg-destructive/10 px-3 py-2 text-xs text-destructive">{data.syncDiagnostics.lastError}</p>
          ) : null}
        </div>
      </article>
    </section>
  </main>
</BaseLayout>