---
import BackToCalendarLink from '@/components/navigation/BackToCalendarLink';
import MonthlyStatsPanel from '@/components/calendar/MonthlyStats';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getRequestAuth } from '@/lib/auth';
import { getStatsPageData } from '@/services/calendar-service';

const auth = getRequestAuth(Astro.locals);
if (!auth.userId) {
  return auth.redirectToSignIn();
}

const year = Number.parseInt(Astro.url.searchParams.get('year') ?? `${new Date().getFullYear()}`, 10);
const data = await getStatsPageData(year, auth.userId);

const previousYearHref = `/estadisticas?year=${year - 1}`;
const nextYearHref = `/estadisticas?year=${year + 1}`;
const calendarHref = `/?year=${year}`;

const totalRegisteredDays = data.monthlyStats.reduce((sum, month) => sum + month.registeredDays, 0);
const totalNoteDays = data.monthlyStats.reduce((sum, month) => sum + month.noteDays, 0);
const activeMonths = data.monthlyStats.filter((month) => month.registeredDays > 0).length;
---

<BaseLayout title={`Estadísticas ${year} | Calendario emocional`} description="Tendencias mensuales de tu calendario emocional.">
  <main class="mx-auto max-w-[1440px] px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
    <section class="grid gap-4 xl:grid-cols-[1.35fr_0.85fr]">
      <article class="surface-panel shadow-soft overflow-hidden rounded-[2rem] border border-white/60">
        <div class="space-y-6 p-6 md:p-8">
          <div class="flex flex-col gap-5 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-3">
              <div class="flex flex-wrap gap-2">
                <span class="inline-flex w-fit items-center rounded-full bg-primary/12 px-3 py-1 text-xs font-semibold text-primary">
                  Tendencias anuales
                </span>
                <span class="inline-flex w-fit items-center rounded-full border border-border bg-white/70 px-3 py-1 text-xs font-semibold text-foreground">
                  Vista separada del calendario
                </span>
              </div>
              <div class="space-y-2">
                <h1 class="max-w-3xl text-5xl leading-none sm:text-6xl">Estadísticas emocionales</h1>
                <p class="max-w-2xl text-sm text-muted-foreground sm:text-base">
                  Analiza el ritmo de registro, los meses más activos y la emoción dominante sin interferir con la captura diaria del calendario.
                </p>
              </div>
            </div>

            <div class="flex flex-wrap gap-3">
              <BackToCalendarLink href={calendarHref} />
            </div>
          </div>

          <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
            <div class="rounded-[1.5rem] bg-white/75 p-4">
              <p class="text-sm text-muted-foreground">Días registrados</p>
              <p class="mt-2 text-3xl font-semibold">{totalRegisteredDays}</p>
            </div>
            <div class="rounded-[1.5rem] bg-white/75 p-4">
              <p class="text-sm text-muted-foreground">Días con nota</p>
              <p class="mt-2 text-3xl font-semibold">{totalNoteDays}</p>
            </div>
            <div class="rounded-[1.5rem] bg-white/75 p-4">
              <p class="text-sm text-muted-foreground">Meses con actividad</p>
              <p class="mt-2 text-3xl font-semibold">{activeMonths}</p>
            </div>
          </div>
        </div>
      </article>

      <article class="surface-panel shadow-soft rounded-[2rem] border border-white/60 p-6">
        <div class="flex items-center justify-between">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-muted-foreground">Año analizado</p>
        </div>

        <div class="mt-5 flex items-center gap-3">
          <a
            href={previousYearHref}
            aria-label="Año anterior"
            class="inline-flex size-11 items-center justify-center rounded-full border border-border bg-white/75 text-lg font-semibold text-foreground transition-all hover:bg-white"
          >
            -
          </a>
          <div class="flex-1 rounded-[1.5rem] bg-white/75 px-4 py-3 text-center text-3xl font-semibold">{year}</div>
          <a
            href={nextYearHref}
            aria-label="Año siguiente"
            class="inline-flex size-11 items-center justify-center rounded-full border border-border bg-white/75 text-lg font-semibold text-foreground transition-all hover:bg-white"
          >
            +
          </a>
        </div>

        <p class="mt-4 text-sm text-muted-foreground">
          Usa esta vista para revisar patrones y vuelve al calendario principal cuando quieras registrar o editar días concretos.
        </p>
      </article>
    </section>

    <section class="mt-6">
      <MonthlyStatsPanel stats={data.monthlyStats} />
    </section>
  </main>
</BaseLayout>